// VULK® RAGG System Database Schema
// This schema extends the main Prisma schema for the RAGG system

model SiteTemplate {
  id          String   @id @default(cuid())
  url         String   @unique
  title       String
  tags        String[] // Array of tags like ["booking", "neon", "glassmorphism"]
  components  Json     // Array of SiteComponent objects
  css         String   @db.Text
  js          String   @db.Text
  screenshots String[] // Array of base64 encoded screenshots
  metadata    Json     // SiteTemplate metadata object
  embedding   Float[]  // Vector embedding for semantic search
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("site_templates")
}

model ComponentTemplate {
  id          String   @id @default(cuid())
  name        String
  type        String   // Button, Card, Hero, etc.
  framework   String   // React, Vue, Svelte, Vanilla
  uiLibrary   String   // TailwindCSS, Bootstrap, Material-UI, Custom
  code        String   @db.Text
  styles      String   @db.Text
  props       String[] // Array of prop names
  tags        String[] // Array of style tags
  metadata    Json     // Component metadata
  embedding   Float[]  // Vector embedding for semantic search
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("component_templates")
}

model StyleTemplate {
  id          String   @id @default(cuid())
  name        String
  type        String   // glassmorphism, neon, 3d, gradient, animation
  css         String   @db.Text
  tailwind    String?  @db.Text // Tailwind classes if applicable
  scss        String?  @db.Text // SCSS if applicable
  tags        String[] // Array of style tags
  metadata    Json     // Style metadata
  embedding   Float[]  // Vector embedding for semantic search
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("style_templates")
}

model AnimationTemplate {
  id          String   @id @default(cuid())
  name        String
  keyframes   String   @db.Text
  duration    String   @default("0.3s")
  timing      String   @default("ease")
  tags        String[] // Array of animation tags
  metadata    Json     // Animation metadata
  embedding   Float[]  // Vector embedding for semantic search
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("animation_templates")
}

model GeneratedProject {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?  @db.Text
  prompt      String   @db.Text
  framework   String   // React, Vue, Svelte, Vanilla
  uiLibrary   String   // TailwindCSS, Bootstrap, Material-UI, Custom
  code        Json     // Generated code structure
  templates   String[] // Array of template IDs used
  metadata    Json     // Project metadata
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("generated_projects")
}

model RAGQuery {
  id          String   @id @default(cuid())
  userId      String
  query       String   @db.Text
  results     Json     // Search results
  filters     Json     // Applied filters
  metadata    Json     // Query metadata
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("rag_queries")
}

// Extend User model to include RAGG relations
model User {
  id                String            @id @default(cuid())
  email             String            @unique
  name              String?
  image             String?
  emailVerified     DateTime?
  accounts          Account[]
  sessions          Session[]
  generatedProjects GeneratedProject[]
  ragQueries        RAGQuery[]

  @@map("users")
}

