{
	"name": "vulk",
	"description": "VULK® - The Voice-Controlled, AI-Powered Full-Stack Platform",
	"version": "0.3.0",
	"private": true,
	"scripts": {
		"dev": "next dev -p 3000 --turbo",
		"dev:ws": "node websocket-server.js",
		"dev:full": "concurrently \"pnpm dev\" \"pnpm dev:ws\"",
		"build": "prisma generate && next build --no-lint",
		"start": "next start",
		"postinstall": "prisma generate",
		"check:engines": "node ./scripts/check-prisma-engines.mjs",
		"lint": "biome check ./src",
		"lint:fix": "biome check --write .",
		"type-check": "tsc --noEmit",
		"pre-deploy": "pnpm type-check && pnpm lint && pnpm build",
		"prepare": "husky",
		"lint:staged": "lint-staged",
		"db:up": "docker compose up -d",
		"db:down": "docker compose down",
		"db:status": "docker ps --filter name=vulk_postgres",
		"db:psql": "docker exec -it vulk_postgres psql -U user -d vulk_db",
		"db:import": "bash scripts/db-import.sh",
		"prisma:generate": "prisma generate",
		"prisma:migrate": "prisma migrate dev --name init",
		"prisma:migrate:deploy": "prisma migrate deploy",
		"prisma:push": "prisma db push",
		"prisma:studio": "prisma studio",
		"prisma:migrate:local": "sh -c 'export $(grep ^DATABASE_URL .env.local | xargs) && prisma migrate dev'",
		"prisma:push:local": "sh -c 'export $(grep ^DATABASE_URL .env.local | xargs) && prisma db push'",
		"prisma:studio:local": "sh -c 'export $(grep ^DATABASE_URL .env.local | xargs) && prisma studio'",
		"db:seed:settings": "node scripts/seed-settings.mjs",
		"ragg:index": "node scripts/index-sites.js",
		"ragg:index-popular": "node scripts/index-popular-sites.js",
		"ragg:generate": "node scripts/index-sites.js generate",
		"ragg:search": "node scripts/index-sites.js search",
		"ragg:list": "node scripts/index-sites.js list"
	},
	"browserslist": "defaults",
	"license": "MIT",
