          <Bullet>First‑mover voice‑to‑code • Produto 95% pronto • Mercado €50B+</Bullet>
          <Bullet>Unit economics de referência (LTV/CAC 30×) • Equipa complementar</Bullet>
        </ul>
        <div className="grid sm:grid-cols-3 gap-4">
          <KeyMetric label="Live Demo" value="Agendar" note="Ver K0D em ação" />
          <KeyMetric label="Due Diligence" value="Pack" note="Tech, legal, financials" />
          <KeyMetric label="Term Sheet" value="Pronto" note="Negociar termos" />
        </div>
        <div className="mt-6 grid sm:grid-cols-2 gap-4">
          <div className="rounded-2xl border border-white/10 bg-white/5 p-5">
            <h3 className="text-lg title-subsection mb-2">Contactos</h3>
            <ul className="space-y-1 ${themeClasses.textSecondary}">
              <li>Investors — investors@k0d.pro</li>
              <li>João Castro — joao@k0d.pro</li>
              <li>Joana Matos — joana@k0d.pro</li>
              <li>Parcerias — partners@k0d.pro</li>
              <li>Press — press@k0d.pro</li>
              <li>Suporte — support@k0d.pro</li>
            </ul>
          </div>
          <div className="rounded-2xl border border-white/10 bg-white/5 p-5">
            <h3 className="text-lg title-subsection mb-2">Links</h3>
            <ul className="space-y-1 ${themeClasses.textSecondary}">
              <li>k0d.pro</li>
              <li>docs.k0d.pro</li>
              <li>status.k0d.pro</li>
              <li>github.com/k0d</li>
            </ul>
          </div>
        </div>
      </div>
    ),
  },
];

export default function Deck() {
  const [index, setIndex] = useState(0);
  const [showTOC, setShowTOC] = useState(true);
  const [isUnlocked, setIsUnlocked] = useState(false);
  const [isDarkMode, setIsDarkMode] = useState(true); // Default to dark mode
  const total = slides.length;
  const current = slides[index];
  const containerRef = useRef(null);

  useEffect(() => {
    const onKey = (e) => {
      if (e.key === "ArrowRight" || e.key.toLowerCase() === "l") setIndex((i) => Math.min(i + 1, total - 1));
      if (e.key === "ArrowLeft" || e.key.toLowerCase() === "h") setIndex((i) => Math.max(i - 1, 0));
      if (e.key.toLowerCase() === "t") setShowTOC((s) => !s);
    };
    window.addEventListener("keydown", onKey);
    return () => window.removeEventListener("keydown", onKey);
  }, [total]);

  const progress = useMemo(() => ((index + 1) / total) * 100, [index, total]);

  // Theme classes
  const themeClasses = isDarkMode ? {
    bg: "bg-[#0b0d10]",
    text: "text-white",
    textSecondary: "${themeClasses.textSecondary}",
    textMuted: "text-white/60",
    border: "border-white/10",
    bgCard: "bg-white/5",
    bgCardHover: "bg-white/10",
    bgGradient: "from-blue-500/20 to-purple-500/20",
    bgGradientGreen: "from-green-500/20 to-blue-500/20",
    bgGradientRed: "from-red-500/20 to-orange-500/20",
    bgGradientPurple: "from-purple-500/20 to-blue-500/20",
    gridPattern: "radial-gradient(circle at 1px 1px, #fff 1px, transparent 0)"
  } : {
    bg: "bg-slate-50",
    text: "text-slate-900",
    textSecondary: "text-slate-700",
    textMuted: "text-slate-500",
    border: "border-slate-200",
    bgCard: "bg-white/95",
    bgCardHover: "bg-white",
    bgGradient: "from-blue-50 to-purple-50",
    bgGradientGreen: "from-green-50 to-blue-50",
    bgGradientRed: "from-red-50 to-orange-50",
    bgGradientPurple: "from-purple-50 to-blue-50",
    gridPattern: "radial-gradient(circle at 1px 1px, #64748b 1px, transparent 0)"
  };

  if (!isUnlocked) {
    return <PasswordProtection onUnlock={() => setIsUnlocked(true)} isDarkMode={isDarkMode} themeClasses={themeClasses} />;
  }

  return (
    <div className={`w-full h-[90vh] sm:h-screen ${themeClasses.bg} ${themeClasses.text} relative overflow-hidden`}>
      {/* Grid layout */}
      <div className="absolute inset-0 opacity-[0.06] pointer-events-none" style={{ backgroundImage: themeClasses.gridPattern, backgroundSize: "22px 22px" }} />

      <div className="relative h-full w-full flex">
        {/* TOC */}
        {showTOC && (
          <aside className={`hidden md:flex w-64 flex-col border-r ${themeClasses.border} ${themeClasses.bgCard} backdrop-blur-sm`}>
            <div className={`px-4 py-3 border-b ${themeClasses.border} flex items-center justify-between`}>
              <div className={`text-xs tracking-widest ${themeClasses.textSecondary}`}>K0D • PITCH v1.0</div>
              <button
                onClick={() => setIsDarkMode(!isDarkMode)}
                className={`flex items-center gap-1 px-2 py-1 rounded-lg ${themeClasses.bgCardHover} ${themeClasses.border} border hover:${themeClasses.bgCard} transition-colors`}
                title={`Switch to ${isDarkMode ? 'light' : 'dark'} mode`}
              >
                {isDarkMode ? <Sun size={12} /> : <Moon size={12} />}
                <span className="text-xs">
                  {isDarkMode ? 'Light' : 'Dark'}
                </span>
              </button>
            </div>
            <nav className="flex-1 overflow-auto px-2 py-2 space-y-1">
              {slides.map((s, i) => (
                <button
                  key={s.id}
                  onClick={() => setIndex(i)}
                  className={`w-full text-left px-2 py-1.5 rounded-lg text-xs transition-colors ${
                    i === index
                      ? `${themeClasses.bgCardHover} ${themeClasses.text}`
                      : `${themeClasses.textSecondary} hover:${themeClasses.bgCardHover}`
                  }`}
                >
                  <div className={`text-xs uppercase tracking-wider ${themeClasses.textMuted}`}>{String(i + 1).padStart(2, "0")}</div>
                  <div className="text-xs font-medium line-clamp-2">{s.title}</div>
                </button>
              ))}
            </nav>
          </aside>
        )}

        {/* Mobile TOC Overlay */}
        {showTOC && (
          <div className="md:hidden fixed inset-0 z-50 bg-black/50 backdrop-blur-sm">
            <div className={`w-80 h-full ${themeClasses.bgCard} border-r ${themeClasses.border} backdrop-blur-sm`}>
              <div className={`px-4 py-3 border-b ${themeClasses.border} flex justify-between items-center`}>
                <div className={`text-xs tracking-widest ${themeClasses.textSecondary}`}>K0D • PITCH v1.0</div>
                <div className="flex items-center gap-2">
                  <button
                    onClick={() => setIsDarkMode(!isDarkMode)}
                    className={`flex items-center gap-1 px-2 py-1 rounded-lg ${themeClasses.bgCardHover} ${themeClasses.border} border hover:${themeClasses.bgCard} transition-colors`}
                    title={`Switch to ${isDarkMode ? 'light' : 'dark'} mode`}
                  >
                    {isDarkMode ? <Sun size={12} /> : <Moon size={12} />}
                    <span className="text-xs">
                      {isDarkMode ? 'Light' : 'Dark'}
                    </span>
                  </button>
                  <button
                    onClick={() => setShowTOC(false)}
                    className={`p-1 rounded ${themeClasses.bgCardHover} ${themeClasses.text}`}
                  >
                    ✕
                  </button>
                </div>
              </div>
              <nav className="flex-1 overflow-auto px-2 py-2 space-y-1">
                {slides.map((s, i) => (
                  <button
                    key={s.id}
                    onClick={() => {
                      setIndex(i);
                      setShowTOC(false);
                    }}
                    className={`w-full text-left px-2 py-1.5 rounded-lg text-xs transition-colors ${
                      i === index
                        ? `${themeClasses.bgCardHover} ${themeClasses.text}`
                        : `${themeClasses.textSecondary} hover:${themeClasses.bgCardHover}`
                    }`}
                  >
                    <div className={`text-xs uppercase tracking-wider ${themeClasses.textMuted}`}>{String(i + 1).padStart(2, "0")}</div>
                    <div className="text-xs font-medium line-clamp-2">{s.title}</div>
                  </button>
                ))}
              </nav>
            </div>
          </div>
        )}

        {/* Slide */}
        <main ref={containerRef} className="flex-1">
          <SlideShell title={current.title} subtitle={current.subtitle} icon={current.icon} themeClasses={themeClasses}>
            {current.content}
          </SlideShell>
        </main>
      </div>

      {/* Overlay for navigation bar */}
      <div className="absolute bottom-0 left-0 right-0 h-20 bg-gradient-to-t from-black/20 to-transparent pointer-events-none" />
      
      {/* Controls */}
      <div className="absolute bottom-4 left-4 right-4 flex items-center gap-3 z-10">
        <button
          onClick={() => setIndex((i) => Math.max(0, i - 1))}
          className={`inline-flex items-center gap-2 px-4 py-2 rounded-xl ${themeClasses.bgCard} border ${themeClasses.border} hover:${themeClasses.bgCardHover} transition`}
        >
          <ArrowLeft size={16} /> Prev
        </button>
        <div className={`flex-1 h-2 rounded-full ${themeClasses.bgCard} overflow-hidden`}>
          <div className={`h-full ${isDarkMode ? 'bg-white/80' : 'bg-blue-600'}`} style={{ width: `${progress}%` }} />
        </div>
        <button
          onClick={() => setIndex((i) => Math.min(total - 1, i + 1))}
          className={`inline-flex items-center gap-2 px-4 py-2 rounded-xl ${themeClasses.bgCard} border ${themeClasses.border} hover:${themeClasses.bgCardHover} transition`}
        >
          Next <ArrowRight size={16} />
        </button>
        <button
          onClick={() => setShowTOC((s) => !s)}
          className={`inline-flex items-center gap-2 px-3 py-2 rounded-xl text-xs uppercase tracking-wider ${themeClasses.bgCard} border ${themeClasses.border} hover:${themeClasses.bgCardHover}`}
        >
          TOC
        </button>
        <div className={`text-xs ${themeClasses.textMuted} ml-auto`}>{index + 1}/{total}</div>
      </div>
    </div>
  );
}
