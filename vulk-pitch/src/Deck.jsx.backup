/**
 * K0D — INVESTOR PITCH DECK (v1.0)
 * Estilo visual: clean, dark, tipografia clara, cartões com glass-morphism leve.
 * Navegação: ← →, click, toc à esquerda (toggle), progress bar inferior.
 * Tech: Tailwind + React (shadcn/ui opcional). Tudo num único componente export default.
 */

// Password protection component
function PasswordProtection({ onUnlock, isDarkMode, themeClasses }) {
  const [password, setPassword] = useState('');
  const [error, setError] = useState('');
  const [isLoading, setIsLoading] = useState(false);

  const handleSubmit = async (e) => {
    e.preventDefault();
    setIsLoading(true);
    setError('');

    // Simulate password check
    setTimeout(() => {
      if (password === 'k0d2025') {
        onUnlock();
      } else {
        setError('Password incorreta. Tenta novamente.');
      }
      setIsLoading(false);
    }, 500);
  };

  return (
    <div className={`fixed inset-0 ${themeClasses.bg} flex items-center justify-center z-50`}>
      <div className={`${themeClasses.bgCard} backdrop-blur-md border ${themeClasses.border} rounded-2xl p-10 max-w-md w-full mx-4 text-center`}>
        <div className="mb-6">
          <h1 className={`text-2xl font-bold ${themeClasses.text} mb-2`}>K0D Pitch Deck</h1>
          <p className={themeClasses.textSecondary}>Introduz a password para aceder</p>
        </div>
        
        <form onSubmit={handleSubmit}>
          <input
            type="password"
            value={password}
            onChange={(e) => setPassword(e.target.value)}
            placeholder="Password"
            className={`w-full px-4 py-3 rounded-xl ${themeClasses.bgCardHover} border ${themeClasses.border} ${themeClasses.text} placeholder-${isDarkMode ? 'white/50' : 'gray-500'} focus:outline-none focus:ring-2 focus:ring-${isDarkMode ? 'white/30' : 'blue-500/30'} mb-4`}
            required
          />
          
          <button
            type="submit"
            disabled={isLoading}
            className={`w-full px-6 py-3 ${themeClasses.bgCardHover} hover:${themeClasses.bgCard} border ${themeClasses.border} ${themeClasses.text} font-medium transition-colors disabled:opacity-50 rounded-xl`}
          >
            {isLoading ? 'A verificar...' : 'Aceder'}
          </button>
        </form>
        
        {error && <div className="text-red-400 mt-4 text-sm">{error}</div>}
        
        <div className={`mt-6 text-xs ${themeClasses.textMuted}`}>
          Contacto: investors@k0d.pro
        </div>
      </div>
    </div>
  );
}

const Section = ({ children, themeClasses }) => (
  <div className={`prose ${themeClasses?.text ? 'prose-invert' : 'prose-gray'} max-w-[92ch] w-full`}>{children}</div>
);

const SlideShell = ({
  title,
  subtitle,
  icon,
  children,
  themeClasses,
}) => {
  return (
    <div className="w-full h-full flex items-center justify-center p-6 sm:p-10">
      <div className={`w-full max-w-[1200px] h-full rounded-2xl ${themeClasses.bgCard} backdrop-blur-md shadow-[0_10px_50px_-10px_rgba(0,0,0,0.6)] border ${themeClasses.border} overflow-hidden flex flex-col`}>
        <div className={`px-6 sm:px-10 pt-8 pb-4 border-b ${themeClasses.border} flex items-center gap-3`}>
          <div className={`flex items-center justify-center w-10 h-10 rounded-xl ${themeClasses.bgCardHover}`}>{icon}</div>
          <div>
            <h2 className="text-xl sm:text-2xl title-section tracking-tight">{title}</h2>
            {subtitle && (
              <p className={`text-sm ${themeClasses.textMuted} leading-tight`}>{subtitle}</p>
            )}
          </div>
        </div>
        <div className="flex-1 overflow-auto px-6 sm:px-10 py-6">
          <Section themeClasses={themeClasses}>{children}</Section>
        </div>
      </div>
    </div>
  );
};

function Bullet({ children, themeClasses }) {
  return (
    <li className={`leading-relaxed marker:${themeClasses?.textMuted || '${themeClasses.textSecondary}'}`}>
      <span className="align-middle">{children}</span>
    </li>
  );
}

function KeyMetric({ label, value, note, themeClasses }) {
  return (
    <div className={`rounded-2xl border ${themeClasses?.border || 'border-white/10'} ${themeClasses?.bgCard || 'bg-white/5'} p-4 sm:p-5`}>
      <div className="text-3xl sm:text-4xl font-semibold tracking-tight">{value}</div>
      <div className={`text-sm sm:text-base ${themeClasses?.textSecondary || '${themeClasses.textSecondary}'} mt-1`}>{label}</div>
      {note && <div className={`text-xs ${themeClasses?.textMuted || '${themeClasses.textMuted}'} mt-2`}>{note}</div>}
    </div>
  );
}

// Interactive Chart Components
function RevenueChart({ isDarkMode }) {
  const data = [
    { year: '2025', revenue: 2.4, users: 1 },
    { year: '2026', revenue: 18, users: 5 },
    { year: '2027', revenue: 72, users: 15 },
    { year: '2028', revenue: 210, users: 35 },
    { year: '2029', revenue: 540, users: 75 }
  ];

  const CustomTooltip = ({ active, payload, label }) => {
    if (active && payload && payload.length) {
      return (
        <div className={`${themeClasses.bgCard} border ${themeClasses.border} rounded-lg p-3 shadow-lg`}>
          <p className={`${themeClasses.text} font-medium`}>{`Year: ${label}`}</p>
          <p className="text-green-400">
            {`Revenue: €${payload[0].value}M`}
          </p>
          <p className="text-blue-400">
            {`Users: ${payload[1].value}K`}
          </p>
        </div>
      );
    }
    return null;
  };

  return (
    <div className="h-80 w-full">
      <ResponsiveContainer width="100%" height="100%">
        <RechartsLineChart data={data} margin={{ top: 20, right: 30, left: 20, bottom: 20 }}>
          <CartesianGrid strokeDasharray="3 3" stroke={isDarkMode ? '#ffffff20' : '#00000020'} />
          <XAxis 
            dataKey="year" 
            stroke="#ffffff60"
            fontSize={12}
          />
          <YAxis 
            stroke="#ffffff60"
            fontSize={12}
          />
          <Tooltip content={<CustomTooltip />} />
          <Line 
            type="monotone" 
            dataKey="revenue" 
            stroke={isDarkMode ? '#10b981' : '#059669'} 
            strokeWidth={3}
            dot={{ fill: isDarkMode ? '#10b981' : '#059669', strokeWidth: 2, r: 6 }}
            activeDot={{ r: 8, stroke: isDarkMode ? '#10b981' : '#059669', strokeWidth: 2 }}
          />
          <Line 
            type="monotone" 
            dataKey="users" 
            stroke={isDarkMode ? '#3b82f6' : '#2563eb'} 
            strokeWidth={3}
            dot={{ fill: isDarkMode ? '#3b82f6' : '#2563eb', strokeWidth: 2, r: 6 }}
            activeDot={{ r: 8, stroke: isDarkMode ? '#3b82f6' : '#2563eb', strokeWidth: 2 }}
          />
        </RechartsLineChart>
      </ResponsiveContainer>
    </div>
  );
}

function MarketShareChart({ isDarkMode }) {
  const data = [
    { name: 'K0D', value: 5, color: isDarkMode ? '#8b5cf6' : '#7c3aed' },
    { name: 'GitHub Copilot', value: 15, color: isDarkMode ? '#6b7280' : '#4b5563' },
    { name: 'Replit', value: 8, color: isDarkMode ? '#3b82f6' : '#2563eb' },
    { name: 'v0.dev', value: 3, color: isDarkMode ? '#10b981' : '#059669' },
    { name: 'Others', value: 69, color: isDarkMode ? '#6b7280' : '#9ca3af' }
  ];

  const CustomTooltip = ({ active, payload }) => {
    if (active && payload && payload.length) {
      return (
        <div className={`${themeClasses.bgCard} border ${themeClasses.border} rounded-lg p-3 shadow-lg`}>
          <p className={`${themeClasses.text} font-medium`}>{payload[0].name}</p>
          <p className={`${themeClasses.textSecondary}`}>
            {`Market Share: ${payload[0].value}%`}
          </p>
        </div>
      );
    }
    return null;
  };

  return (
    <div className="h-80 w-full">
      <ResponsiveContainer width="100%" height="100%">
        <PieChart>
          <Pie
            data={data}
            cx="50%"
            cy="50%"
            innerRadius={60}
            outerRadius={120}
            paddingAngle={5}
            dataKey="value"
          >
            {data.map((entry, index) => (
              <Cell key={`cell-${index}`} fill={entry.color} />
            ))}
          </Pie>
          <Tooltip content={<CustomTooltip />} />
        </PieChart>
      </ResponsiveContainer>
    </div>
  );
}

function GrowthAreaChart({ isDarkMode }) {
  const data = [
    { month: 'Jan', growth: 0 },
    { month: 'Feb', growth: 15 },
    { month: 'Mar', growth: 35 },
    { month: 'Apr', growth: 60 },
    { month: 'May', growth: 90 },
    { month: 'Jun', growth: 125 },
    { month: 'Jul', growth: 165 },
    { month: 'Aug', growth: 210 },
    { month: 'Sep', growth: 260 },
    { month: 'Oct', growth: 315 },
    { month: 'Nov', growth: 375 },
    { month: 'Dec', growth: 440 }
  ];

  const CustomTooltip = ({ active, payload, label }) => {
    if (active && payload && payload.length) {
      return (
        <div className={`${themeClasses.bgCard} border ${themeClasses.border} rounded-lg p-3 shadow-lg`}>
          <p className={`${themeClasses.text} font-medium`}>{`Month: ${label}`}</p>
          <p className="text-purple-400">
            {`Growth: ${payload[0].value}%`}
          </p>
        </div>
      );
    }
    return null;
  };

  return (
    <div className="h-80 w-full">
      <ResponsiveContainer width="100%" height="100%">
        <AreaChart data={data} margin={{ top: 20, right: 30, left: 20, bottom: 20 }}>
          <defs>
            <linearGradient id="colorGrowth" x1="0" y1="0" x2="0" y2="1">
              <stop offset="5%" stopColor={isDarkMode ? '#8b5cf6' : '#7c3aed'} stopOpacity={0.8}/>
              <stop offset="95%" stopColor={isDarkMode ? '#8b5cf6' : '#7c3aed'} stopOpacity={0.1}/>
            </linearGradient>
          </defs>
          <CartesianGrid strokeDasharray="3 3" stroke={isDarkMode ? '#ffffff20' : '#00000020'} />
          <XAxis 
            dataKey="month" 
            stroke="#ffffff60"
            fontSize={12}
          />
          <YAxis 
            stroke="#ffffff60"
            fontSize={12}
          />
          <Tooltip content={<CustomTooltip />} />
          <Area 
            type="monotone" 
            dataKey="growth" 
            stroke={isDarkMode ? '#8b5cf6' : '#7c3aed'} 
            fillOpacity={1} 
            fill="url(#colorGrowth)" 
            strokeWidth={3}
          />
        </AreaChart>
      </ResponsiveContainer>
    </div>
  );
}

